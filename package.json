{
  "author": "chris",
  "email": "kispi@naver.com",
  "name": "coinsect_frontend",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "serve": "vue-cli-service serve --port 4000",
    "build": "vue-cli-service build",
    "build-dev": "vue-cli-service build --mode development",
    "lint": "vue-cli-service lint",
    "build:client": "vue-cli-service build --dest dist-temp/client",
    "build:server": "cross-env VUE_APP_SSR=true vue-cli-service build --dest dist-temp/server",
    "build:ssr": "npm run build:client && npm run build:server && rm -rf dist && mv dist-temp dist",
    "serve:ssr": "cross-env NODE_ENV=production node was/server.js",
    "build-dev:client": "vue-cli-service build --dest dist-dev-temp/client --mode development",
    "build-dev:server": "cross-env VUE_APP_SSR=true vue-cli-service build --dest dist-dev-temp/server --mode development",
    "build-dev:ssr": "npm run build-dev:client && npm run build-dev:server && rm -rf dist-dev && mv dist-dev-temp dist-dev",
    "serve-dev:ssr": "cross-env NODE_ENV=development node was/server.js"
  },
  "dependencies": {
    "@vue/server-renderer": "^3.2.47",
    "axios": "^1.3.2",
    "core-js": "^3.8.3",
    "dayjs": "^1.11.7",
    "vue": "^3.2.13",
    "vue-router": "^4.1.6",
    "vuex": "^4.1.0",
    "webpack-manifest-plugin": "^5.0.0",
    "webpack-node-externals": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "babel-eslint": "^10.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "sass": "^1.58.0",
    "sass-loader": "^13.2.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "babel-eslint"
    },
    "rules": {
      "no-unused-vars": "off",
      "no-empty": "off",
      "no-undef": "off",
      "vue/return-in-computed-property": "off",
      "vue/no-side-effects-in-computed-properties": "off",
      "vue/no-unused-components": "warn"
    }
  },
  "prettier": {
    "singleQuote": true,
    "semi": false,
    "trailingComma": "es5"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
